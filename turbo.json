{
    "tasks": {
        "build:watch": {
            "cache": false,
            "persistent": true
        },
        "build": {
            "dependsOn": ["^build"],
            "outputs": []
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "typecheck": {
            "cache": false,
            "persistent": true
        },
        "test": {
            "dependsOn": ["^build"]
        },
        "test:coverage": {
            "dependsOn": ["^build"]
        }
    },
    "ui": "tui",
    "cacheDir": ".turbo/cache"
}
