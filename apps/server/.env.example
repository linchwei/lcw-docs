# 数据库
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=postgres

# JWT
JWT_SECRET=your-jwt-secret-here

# AI
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-v4-flash

# LLM 提供商（openai | deepseek）
LLM_PROVIDER=deepseek

# OpenAI（可选）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# LangGraph Checkpointer Schema（可选，默认 langgraph）
LANGGRAPH_SCHEMA=langgraph

# CORS
CORS_ORIGINS=http://localhost:5173

# Redis (可选，Bull 队列需要)
REDIS_HOST=localhost
REDIS_PORT=6379

# Sentry (可选，错误追踪)
SENTRY_DSN=

# RAG / Embedding 配置（可选，不配置则 RAG 语义搜索降级为关键词搜索）
# Embedding 提供商：dashscope（阿里云百炼，推荐，中文效果最佳）或 openai
EMBEDDING_PROVIDER=dashscope
# Embedding API Key（阿里云百炼：https://bailian.console.aliyun.com/ ；OpenAI：https://platform.openai.com/）
EMBEDDING_API_KEY=
# Embedding 模型名称（dashscope: text-embedding-v3, openai: text-embedding-3-small）
EMBEDDING_MODEL=text-embedding-v3
# 向量维度（dashscope 默认 1024，openai 默认 1536）
EMBEDDING_DIMENSIONS=1024
