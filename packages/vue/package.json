{
    "name": "@lcw-doc/vue",
    "private": false,
    "sideEffects": [
        "*.css"
    ],
    "license": "",
    "version": "0.0.1",
    "description": "Vue 3 编辑器组件库 - 基于 Prosemirror 和 Tiptap 实现的类 Notion、飞书文档风格可扩展文本编辑器。",
    "type": "module",
    "source": "src/index.ts",
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "scripts": {
        "build:watch": "tsup --watch",
        "build": "tsup && vue-tsc -p tsconfig.declaration.json --emitDeclarationOnly",
        "clean": "rimraf dist",
        "typecheck": "vue-tsc --noEmit"
    },
    "dependencies": {
        "@floating-ui/vue": "^1.1.11",
        "@lcw-doc/core": "workspace:*",
        "@tiptap/core": "^2.27.2",
        "@tiptap/pm": "^2.27.2",
        "@tiptap/vue-3": "^2.27.2"
    },
    "peerDependencies": {
        "vue": "^3.5.0"
    },
    "devDependencies": {
        "esbuild-plugin-vue-next": "^0.1.4",
        "rimraf": "^6.1.3",
        "tsup": "^8.5.1",
        "vue": "^3.5.0",
        "vue-tsc": "^2.2.12"
    }
}
