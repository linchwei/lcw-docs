{
    "name": "@lcw-doc/core",
    "private": false,
    "sideEffects": [
        "*.css"
    ],
    "license": "",
    "version": "1.19.0",
    "keywords": [
        "lcw",
        "editor",
        "typescript",
        "prosemirror",
        "wysiwyg",
        "rich-text-editor",
        "feishu",
        "notion",
        "yjs",
        "block-based",
        "tiptap"
    ],
    "description": "基于 Prosemirror 和 Tiptap 实现的类 Notion、飞书文档风格可扩展文本编辑器。",
    "type": "module",
    "source": "src/index.ts",
    "main": "build/cjs/index.js",
    "module": "build/esm/index.js",
    "exports": {
        ".": {
            "types": "./build/esm/index.d.ts",
            "import": "./build/esm/index.js"
        },
        "./style.css": {
            "import": "./build/esm/index.css"
        }
    },
    "scripts": {
        "build:watch": "tsup --watch",
        "build": "tsup",
        "clean": "rimraf build",
        "typecheck": "tsc --noEmit",
        "test": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@emoji-mart/data": "^1.2.1",
        "@floating-ui/dom": "^1.6.0",
        "@tiptap/core": "^3.26.1",
        "@tiptap/extension-bold": "^3.26.1",
        "@tiptap/extension-code": "^3.26.1",
        "@tiptap/extension-collaboration": "^3.26.1",
        "@tiptap/extension-collaboration-caret": "^3.26.1",
        "@tiptap/extension-hard-break": "^3.26.1",
        "@tiptap/extension-horizontal-rule": "^3.26.1",
        "@tiptap/extension-italic": "^3.26.1",
        "@tiptap/extension-link": "^3.26.1",
        "@tiptap/extension-paragraph": "^3.26.1",
        "@tiptap/extension-strike": "^3.26.1",
        "@tiptap/extension-table": "^3.26.1",
        "@tiptap/extension-text": "^3.26.1",
        "@tiptap/extension-underline": "^3.26.1",
        "@tiptap/extensions": "^3.26.1",
        "@tiptap/pm": "^3.26.1",
        "emoji-mart": "^5.6.0",
        "hast-util-from-dom": "^5.0.1",
        "katex": "^0.16.47",
        "prosemirror-highlight": "^0.15.1",
        "prosemirror-model": "^1.25.4",
        "prosemirror-state": "^1.4.4",
        "prosemirror-tables": "^1.8.5",
        "prosemirror-transform": "^1.12.0",
        "prosemirror-view": "^1.41.8",
        "refractor": "^5.0.0",
        "rehype-format": "^5.0.1",
        "rehype-parse": "^9.0.1",
        "rehype-remark": "^10.0.1",
        "rehype-stringify": "^10.0.1",
        "remark-gfm": "^4.0.1",
        "remark-parse": "^11.0.0",
        "remark-rehype": "^11.1.2",
        "remark-stringify": "^11.0.0",
        "unified": "^11.0.5",
        "uuid": "^13.0.0",
        "y-prosemirror": "1.3.7",
        "y-protocols": "^1.0.7",
        "yjs": "^13.6.30"
    },
    "devDependencies": {
        "@types/emoji-mart": "^5.3.0",
        "@types/hast": "^3.0.4",
        "@types/uuid": "^11.0.0",
        "@vitest/coverage-v8": "^4.1.4",
        "jsdom": "^29.0.2",
        "vitest": "^4.1.4"
    }
}
